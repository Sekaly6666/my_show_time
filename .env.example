# Local development example
MONGODB_URI=mongodb://127.0.0.1:27017/my_show_time
JWT_SECRET=change_this_secret
PORT=3001
APP_URL=http://localhost:3001

# Production notes:
# - Use a MongoDB Atlas mongodb+srv:// URI on Vercel/Render/Railway.
# - Set APP_URL to your public frontend URL, for example https://my-show-time.vercel.app.